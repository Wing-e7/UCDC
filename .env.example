# Copy to `.env` and adjust. Docker Compose loads `.env` for variable substitution.
# For production, set a strong JWT_SECRET and UCDC_ENV=production.

UCDC_ENV=dev
JWT_SECRET=dev-change-me-dev-change-me-dev-change-me
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/ucdc
LOG_LEVEL=INFO
AGENT_ADAPTER_BASE_URL=http://127.0.0.1:8003
