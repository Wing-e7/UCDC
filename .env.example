# Copy to `.env` and adjust. Docker Compose loads `.env` for variable substitution.
# For production, set a strong JWT_SECRET and UCDC_ENV=production.

UCDC_ENV=dev
JWT_SECRET=dev-change-me-dev-change-me-dev-change-me
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/ucdc
LOG_LEVEL=INFO

# In Docker, orchestrator/worker use service DNS; these are for the host browser and third-party clients.
AGENT_ADAPTER_BASE_URL=http://127.0.0.1:8003
UCDC_PUBLIC_CONSENT_BASE_URL=http://127.0.0.1:8001
UCDC_PUBLIC_ORCHESTRATOR_BASE_URL=http://127.0.0.1:8002
UCDC_PUBLIC_AGENT_ADAPTER_BASE_URL=http://127.0.0.1:8003
# Must match the agent_id your adapter exposes (skeleton default: example-agent).
UCDC_DEFAULT_AGENT_ID=example-agent

# Set true on orchestrator for 202 + queued jobs; run `python -m ucdc.job_worker` (or compose profile async).
UCDC_ASYNC_JOBS=false
UCDC_DEFAULT_MAX_CONCURRENT_JOBS=10
# Comma-separated browser origins for /ui demo, or * for local dev only
CORS_ORIGINS=*

# Optional: one-click “Set-Up / New Set-Up / Execute” in /ui runs subprocesses in your Staffer clone (dev only; never in production).
# UCDC_ENABLE_STAFFER_LOCAL_BRIDGE=true
# STAFFER_LOCAL_REPO=/absolute/path/to/The_Staffer_UCDC
# Defaults match common entrypoints; override if yours differ (e.g. UCDC_STAFFER_CMD_SETUP=python run_config.py).
# UCDC_STAFFER_CMD_SETUP=python run_config.py
# UCDC_STAFFER_CMD_SETUP_NEW=python run_config.py --overwrite
# UCDC_STAFFER_CMD_EXECUTE=python main.py --fresh
